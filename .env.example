# Server
HOST=0.0.0.0
PORT=8000

# ADB
ADB_PATH=adb
ADB_POLL_INTERVAL=3.0

# scrcpy
SCRCPY_SERVER_PATH=scrcpy-server
SCRCPY_VERSION=3.1
VIDEO_BITRATE=2000000

# Port range for ADB forwarding (one port per device)
PORT_RANGE_START=27183
PORT_RANGE_END=27199

# Session grace period before stopping when last client disconnects (seconds)
SESSION_GRACE_PERIOD=30
